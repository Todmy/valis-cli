# Valis Community Edition — environment
# Copy to .env, then run ./generate-keys.sh to fill the secret/JWT values.
# NEVER commit your real .env.

############
# Postgres
############
POSTGRES_DB=postgres
POSTGRES_PORT=5432
# Strong password for the database superuser + all Supabase service roles.
POSTGRES_PASSWORD=change-me-to-a-long-random-password

############
# JWT / API keys  (generate-keys.sh fills these three)
############
# Symmetric secret (>= 32 chars) used to sign + verify all JWTs.
JWT_SECRET=change-me-to-a-32-char-min-random-secret
JWT_EXPIRY=3600
# anon + service_role keys are JWTs signed with JWT_SECRET above.
# The CLI uses SERVICE_ROLE_KEY. Regenerate whenever JWT_SECRET changes.
ANON_KEY=
SERVICE_ROLE_KEY=

############
# API gateway (Kong) — this host:port is the SUPABASE URL the CLI points at
############
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
API_EXTERNAL_URL=http://localhost:8000
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=

############
# GoTrue (Auth) behaviour
############
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=true

############
# PostgREST
############
PGRST_DB_SCHEMAS=public

############
# Qdrant
############
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
